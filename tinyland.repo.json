{
	"$schema": "./docs/schemas/tinyland-repo-manifest.schema.json",
	"schema_version": 1,
	"scaffold_tag": "v0.2.0",
	"repo": {
		"name": "greatfallstoolbus.org",
		"github": "Great-Falls-Tool-Bus/greatfallstoolbus.org",
		"domain": "greatfallstoolbus.org",
		"description": "Great Falls Tool Bus - a shared tool library on wheels for Lewiston-Auburn, Maine. This is a bus; the shop comes later :)",
		"linear": {
			"initiative": "TIN-1437",
			"issue": "TIN-2360"
		}
	},
	"taxonomy": {
		"primary_role": "static-spoke",
		"layers": ["org-wide-repo-contract", "bazel-package-cache-rbe", "static-spoke"]
	},
	"enrollment": {
		"forgeScope": "Great-Falls-Tool-Bus",
		"operatorOverlay": "great-falls-tool-bus-infra",
		"executionPool": "tinyland-nix",
		"substrateMode": "shared-cache-backed"
	},
	"contracts": {
		"agent_contract": "AGENTS.md",
		"just": "Justfile",
		"nix": "flake.nix",
		"github_actions": ".github/workflows",
		"secrets_scan": "gitleaks",
		"conformance": "just conformance"
	},
	"boundaries": {
		"owns_runtime_backend": false,
		"owns_auth": false,
		"owns_payments": false,
		"owns_activitypub_delivery": false,
		"owns_live_broker_fetch": false,
		"owns_static_projection_ingest": true,
		"owns_gitops_apply": false,
		"owns_cloudflare_mutation": false,
		"owns_bazel_module_authority": false
	},
	"authorities": {
		"content_authority": "tinyland.dev",
		"gitops_receiver": "tinyland-inc/blahaj",
		"ci_templates": "tinyland-inc/ci-templates",
		"cache_rbe_authority": "tinyland-inc/GloriousFlywheel",
		"tofu_module_authority": "tinyland-inc/GloriousFlywheel",
		"package_registry": "tinyland-inc/bazel-registry"
	},
	"supply_chain": {
		"sbom": {
			"status": "recipe-available",
			"formats": ["CycloneDX JSON", "SPDX JSON"],
			"notes": "Run `just sbom` to generate ignored local SBOM artifacts under build/sbom/. Publication should become a standard ci-templates or release artifact before status moves to generated."
		}
	}
}
