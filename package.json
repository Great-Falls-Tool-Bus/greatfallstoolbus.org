{
	"name": "greatfallstoolbus",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Tinyland house scaffold for static SvelteKit brand sites (Skeleton 4 + Bazel + Nix + Just)",
	"homepage": "https://github.com/Great-Falls-Tool-Bus/greatfallstoolbus.org",
	"repository": {
		"type": "git",
		"url": "https://github.com/Great-Falls-Tool-Bus/greatfallstoolbus.org.git"
	},
	"license": "MIT",
	"packageManager": "pnpm@10.13.1",
	"engines": {
		"node": ">=22 <25"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest",
		"test:unit": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"optimize:images": "node scripts/optimize-images.js",
		"analyze": "ANALYZE=1 vite build"
	},
	"dependencies": {
		"@fontsource-variable/fira-code": "^5.2.7",
		"@fontsource-variable/fraunces": "^5.2.9",
		"@fontsource/crimson-pro": "^5.2.8",
		"@fontsource/inter": "^5.2.8",
		"@lucide/svelte": "^1.23.0",
		"@tummycrypt/tinyland-color-utils": "0.2.3",
		"@tummycrypt/tinyvectors": "0.3.0",
		"effect": "^3.21.4"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@skeletonlabs/skeleton": "4.15.2",
		"@skeletonlabs/skeleton-svelte": "4.15.2",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.2",
		"@tummycrypt/vite-plugin-a11y": "0.2.2",
		"@tummycrypt/vite-plugin-skeleton-colors": "0.2.2",
		"@types/node": "^22.20.1",
		"@vitest/coverage-v8": "^4.1.10",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"mdsvex": "0.12.7",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"rollup-plugin-visualizer": "^7.0.1",
		"serve": "^14.2.6",
		"sharp": "^0.35.3",
		"shiki": "^4.3.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"svgo": "^4.0.1",
		"tailwindcss": "^4.3.2",
		"tsx": "^4.23.0",
		"typescript": "6.0.3",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild",
			"sharp"
		]
	}
}
